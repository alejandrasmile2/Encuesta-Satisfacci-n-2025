  { key: "_14_c_mo_califica_usted_al_tiem", label: "P14. ¿Cómo califica el tiempo de atención?" },
  { key: "_15_c_mo_califica_usted_al_nive", label: "P15. ¿Cómo califica el nivel del personal?" },
  { key: "_16_c_mo_considera_usted_a_la_i", label: "P16. ¿Cómo considera las instalaciones?" },
  { key: "_17_de_manera_general_independi", label: "P17. De manera general, ¿cómo califica el servicio?" },
  { key: "_18_c_mo_considera_usted_al_tie", label: "P18. ¿Cómo considera el tiempo de respuesta a reclamos?" },
  { key: "_19_considera_usted_que_al_real", label: "P19. ¿Al realizar un reclamo se resuelve favorablemente?" },
  { key: "_20_cu_ndo_usted_realiza_un_rec", label: "P20. ¿Cuándo realiza un reclamo se resuelve?" },
  { key: "_7_secci_n_nica_alumbrado_p_bli", label: "P-AP1. ¿Cómo califica el alumbrado público?" },
  { key: "_2_c_mo_califica_al_tiempo_tras", label: "P-AP2. ¿Cómo califica el tiempo para reparar alumbrado?" },
  { key: "_3_c_mo_califica_usted_al_servi", label: "P-AP3. ¿Cómo califica el servicio de alumbrado público?" },
];

const PALETTE = ["#ff4500","#1a6fd4","#ff6b35","#0d3b7a","#ff8c5a","#2980d4","#ffa87a","#1557a0","#ffc4a0","#0e3060"];
const PIE_COLORS = ["#ff4500","#1a6fd4","#ff6b35","#0d3b7a","#ff8c5a","#2980d4","#ffa87a","#1557a0"];

let chartType = "bar";
let mainChartInst = null;
let pieChartInst = null;
let cantonChartInst = null;
let tarifaChartInst = null;

// Populate question dropdown
const selQ = document.getElementById("sel-pregunta");
QUESTIONS.forEach((q, i) => {
  const opt = document.createElement("option");
  opt.value = i;
  opt.textContent = q.label;
  selQ.appendChild(opt);
});

function extractScore(val) {
  if (!val) return null;
  const m = val.match(/(\d+)\s*$/);
  return m ? parseInt(m[1]) : null;
}

function setChart(type) {
  chartType = type;
  document.getElementById("btn-bar").classList.toggle("active", type === "bar");
  document.getElementById("btn-pie").classList.toggle("active", type === "pie");
  render();
}

function getFiltered() {
  const canton = document.getElementById("sel-canton").value;
  const tarifa = document.getElementById("sel-tarifa").value;
  return SURVEY_DATA.filter(r => {
    if (canton !== "Todos" && r.canton !== canton) return false;
    if (tarifa !== "Todos" && r.tarifa !== tarifa) return false;
    return true;
  });
}

function getChartData(filtered, qKey) {
  const counts = {};
  filtered.forEach(r => {
    const raw = r[qKey];
    const label = raw ? raw.trim() : "Sin respuesta";
    counts[label] = (counts[label] || 0) + 1;
  });
  return Object.entries(counts)
    .map(([name, count]) => ({ name, count, score: extractScore(name) }))
    .sort((a, b) => {
      if (a.score !== null && b.score !== null) return a.score - b.score;
      return b.count - a.count;
    });
}

function render() {
  const filtered = getFiltered();
  const canton = document.getElementById("sel-canton").value;
  const tarifa = document.getElementById("sel-tarifa").value;
  const qIdx = parseInt(document.getElementById("sel-pregunta").value);
  const q = QUESTIONS[qIdx];
  const total = filtered.length;

  // KPIs
  document.getElementById("kpi-total").textContent = total;
  document.getElementById("kpi-canton").textContent = canton === "Todos" ? "11 cantones" : canton;
  document.getElementById("kpi-tarifa").textContent = tarifa;

  const scores = filtered.map(r => extractScore(r[q.key])).filter(s => s !== null && s !== 6);
  const avg = scores.length ? (scores.reduce((a,b)=>a+b,0)/scores.length).toFixed(2) : "N/D";
  document.getElementById("kpi-score").textContent = avg !== "N/D" ? avg + " / 5" : "N/D";

  // Chart title
  document.getElementById("chart-title").textContent = q.label;
  document.getElementById("chart-subtitle").textContent =
    total + " respuestas · " + (canton !== "Todos" ? canton : "Todos los cantones") + " · " + (tarifa !== "Todos" ? tarifa : "Todas las tarifas");

  const chartData = getChartData(filtered, q.key);
  const labels = chartData.map(d => d.name);
  const values = chartData.map(d => d.count);
  const colors = chartData.map((_, i) => PALETTE[i % PALETTE.length]);

  // Show/hide chart containers
  document.getElementById("chart-wrap-bar").style.display = chartType === "bar" ? "block" : "none";
  document.getElementById("chart-wrap-pie").style.display = chartType === "pie" ? "block" : "none";

  if (chartType === "bar") {
    if (mainChartInst) mainChartInst.destroy();
    mainChartInst = new Chart(document.getElementById("mainChart"), {
      type: "bar",
      data: { labels, datasets: [{ data: values, backgroundColor: colors, borderRadius: 6, borderSkipped: false }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.raw} respuestas (${((ctx.raw/total)*100).toFixed(1)}%)` } } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 11 } } },
          y: { grid: { color: "#ffe8df" }, ticks: { font: { size: 11 } } }
        }
      }
    });
  } else {
    if (pieChartInst) pieChartInst.destroy();
    pieChartInst = new Chart(document.getElementById("pieChart"), {
      type: "pie",
      data: { labels, datasets: [{ data: values, backgroundColor: PIE_COLORS.slice(0, values.length) }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: "bottom", labels: { font: { size: 11 }, padding: 12 } },
          tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw} (${((ctx.raw/total)*100).toFixed(1)}%)` } }
        }
      }
    });
  }

  // Frequency table
  let rows = chartData.map((row, i) => {
    const pct = ((row.count / total) * 100).toFixed(1);
    return `<tr>
      <td>${row.name}</td>
      <td class="num">${row.count}</td>
      <td class="pct">${pct}%</td>
      <td style="width:35%"><div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:${PALETTE[i%PALETTE.length]}"></div></div></td>
    </tr>`;
  }).join("");
  document.getElementById("freq-table").innerHTML = `<table>
    <thead><tr><th>Respuesta</th><th class="center">Frecuencia</th><th class="center">Porcentaje</th><th></th></tr></thead>
    <tbody>${rows}<tr class="total-row"><td>TOTAL</td><td class="num">${total}</td><td class="pct">100%</td><td></td></tr></tbody>
  </table>`;

  // Canton chart
  const cantonCounts = {};
  filtered.forEach(r => { cantonCounts[r.canton] = (cantonCounts[r.canton] || 0) + 1; });
  const cantonEntries = Object.entries(cantonCounts).sort((a,b) => b[1]-a[1]);
  if (cantonChartInst) cantonChartInst.destroy();
  cantonChartInst = new Chart(document.getElementById("cantonChart"), {
    type: "bar",
    data: {
      labels: cantonEntries.map(e=>e[0]),
      datasets: [{ data: cantonEntries.map(e=>e[1]), backgroundColor: cantonEntries.map((_,i)=>i%2===0?`hsl(${15+i*3},100%,${50+i}%)`:`hsl(${215+i*3},65%,${45+i}%)`), borderRadius: 4 }]
    },
    options: {
      indexAxis: "y", responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.raw} encuestas` } } },
      scales: {
        x: { grid: { color: "#ffe8df" }, ticks: { font: { size: 10 } } },
        y: { grid: { display: false }, ticks: { font: { size: 10 } } }
      }
    }
  });

  // Tarifa chart
  const tarifaCounts = {};
  filtered.forEach(r => { tarifaCounts[r.tarifa] = (tarifaCounts[r.tarifa] || 0) + 1; });
  const tarifaEntries = Object.entries(tarifaCounts);
  if (tarifaChartInst) tarifaChartInst.destroy();
  tarifaChartInst = new Chart(document.getElementById("tarifaChart"), {
    type: "doughnut",
    data: {
      labels: tarifaEntries.map(e=>e[0]),
      datasets: [{ data: tarifaEntries.map(e=>e[1]), backgroundColor: ["#ff4500","#1a6fd4","#ff6b35"] }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: "bottom", labels: { font: { size: 11 }, padding: 10 } },
        tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw} encuestas` } }
      }
    }
  });

  document.getElementById("footer-text").textContent =
    "Dashboard Encuesta de Satisfacción · " + total + " registros filtrados de 817 totales";
}

render();
</script>
</body>
</html>
